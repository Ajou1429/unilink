# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini AI (무료 티어: 하루 1500요청)
# 발급: https://aistudio.google.com → Get API key
GEMINI_API_KEY=AIza...

# Google OAuth (Supabase 대시보드에서 Google Provider 설정 후 자동 처리됨)
# Google Cloud Console → OAuth 2.0 클라이언트 → Drive API 활성화
# Supabase Dashboard → Authentication → Providers → Google
# 추가 스코프: https://www.googleapis.com/auth/drive.file
