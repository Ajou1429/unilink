# Supabase (Next.js 빌드에 포함되는 공개 값)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 아래 값들은 .env.local이 아니라 Supabase Edge Function 시크릿으로 등록합니다.
# supabase secrets set GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=... 등
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://<project-ref>.supabase.co/functions/v1/google-auth/callback
# GOOGLE_DRIVE_WEBHOOK_TOKEN=       # openssl rand -hex 32
# DRIVE_TOKEN_ENC_KEY=              # openssl rand -base64 32 (AES-256-GCM 키, refresh_token 암호화용)
# CRON_SECRET=                      # openssl rand -hex 32 (pg_cron -> drive-renew-channels 검증용)
# FRONTEND_URL=https://<domain>/unilink
